rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@twezimbe.co.ug';
    }

    function isAdminByProfile() {
      return isSignedIn() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isAdmin() {
      return isBootstrapAdmin() || isAdminByProfile();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isAdmin() ||
          (isOwner(userId) &&
              (
                !('isAdmin' in request.resource.data) ||
                request.resource.data.isAdmin == false ||
                isBootstrapAdmin()
              ));

      allow update: if isAdmin() ||
          (isOwner(userId) &&
              (
                !('isAdmin' in request.resource.data) ||
                request.resource.data.isAdmin == resource.data.isAdmin
              ));

      allow delete: if isAdmin() || isOwner(userId);

      match /{subPath=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /adminRequests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
